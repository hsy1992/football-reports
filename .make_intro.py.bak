# -*- coding: utf-8 -*-
"""横版图文系统介绍 PDF（4 页）。"""
from reportlab.lib import colors
from reportlab.lib.pagesizes import A4, landscape
from reportlab.lib.styles import ParagraphStyle
from reportlab.pdfbase import pdfmetrics
from reportlab.pdfbase.pdfmetrics import registerFontFamily
from reportlab.pdfbase.ttfonts import TTFont
from reportlab.pdfgen import canvas
from reportlab.platypus import Paragraph

W, H = landscape(A4)  # 842 x 595
NAVY = colors.HexColor("#1a3e6e")
NAVY_D = colors.HexColor("#122c4f")
GREEN = colors.HexColor("#0a7a2f")
GRAY = colors.HexColor("#5a6572")
LGRAY = colors.HexColor("#aeb8c2")
CARD_BG = colors.HexColor("#f4f7fb")
CARD_BD = colors.HexColor("#d8e0ea")
DARK = colors.HexColor("#222a33")

pdfmetrics.registerFont(TTFont("Hei", "/System/Library/Fonts/STHeiti Light.ttc", subfontIndex=0))
pdfmetrics.registerFont(TTFont("HeiB", "/System/Library/Fonts/STHeiti Medium.ttc", subfontIndex=0))
registerFontFamily("Hei", normal="Hei", bold="HeiB", italic="Hei", boldItalic="HeiB")

OUT = "/Users/d.hw/Documents/D.Haowen/足球预测/reports/系统介绍.pdf"
c = canvas.Canvas(OUT, pagesize=(W, H))


def para(x, y_top, w, text, size=9.5, leading=15, color=DARK, font="Hei"):
    st = ParagraphStyle("p", fontName=font, fontSize=size, leading=leading,
                        textColor=color)
    p = Paragraph(text, st)
    _, ph = p.wrap(w, 1000)
    p.drawOn(c, x, y_top - ph)
    return ph


def nbox(x, y, w, h, lines, fill=NAVY, tc=colors.white, fs=10.5, fs2=8,
         stroke=None):
    c.setFillColor(fill)
    c.setStrokeColor(stroke or fill)
    c.roundRect(x, y, w, h, 7, fill=1, stroke=1)
    n = len(lines)
    total = n * (fs + 4)
    ty = y + h / 2 + total / 2 - fs
    for i, ln in enumerate(lines):
        c.setFillColor(tc)
        f, s = ("HeiB", fs) if i == 0 else ("Hei", fs2 + 1.5)
        c.setFont(f, s)
        c.drawCentredString(x + w / 2, ty, ln)
        ty -= (fs + 4)


def card(x, y, w, h, title=None):
    c.setFillColor(CARD_BG)
    c.setStrokeColor(CARD_BD)
    c.roundRect(x, y, w, h, 9, fill=1, stroke=1)
    if title:
        c.setFillColor(NAVY)
        c.setFont("HeiB", 11.5)
        c.drawString(x + 14, y + h - 24, title)
        c.setStrokeColor(NAVY)
        c.setLineWidth(2)
        c.line(x + 14, y + h - 30, x + 44, y + h - 30)
        c.setLineWidth(1)


def arrow(x1, y1, x2, y2, color=LGRAY, width=1.6):
    c.setStrokeColor(color)
    c.setFillColor(color)
    c.setLineWidth(width)
    c.line(x1, y1, x2, y2)
    import math
    ang = math.atan2(y2 - y1, x2 - x1)
    L, sp = 7, 0.45
    p = c.beginPath()
    p.moveTo(x2, y2)
    p.lineTo(x2 - L * math.cos(ang - sp), y2 - L * math.sin(ang - sp))
    p.lineTo(x2 - L * math.cos(ang + sp), y2 - L * math.sin(ang + sp))
    p.close()
    c.drawPath(p, fill=1, stroke=0)
    c.setLineWidth(1)


def header(num, title, sub):
    c.setFillColor(NAVY)
    c.rect(0, H - 64, W, 64, fill=1, stroke=0)
    c.setFillColor(colors.HexColor("#9fb6d9"))
    c.setFont("HeiB", 22)
    c.drawString(40, H - 44, num)
    c.setFillColor(colors.white)
    c.setFont("HeiB", 17)
    c.drawString(92, H - 42, title)
    c.setFillColor(colors.HexColor("#b9c8de"))
    c.setFont("Hei", 9.5)
    c.drawString(92, H - 57, sub)


def footer(page):
    c.setFillColor(LGRAY)
    c.setFont("Hei", 8)
    c.drawString(40, 22, "足球赛前数据采集与盘口解析系统 · 纯数据研究工具")
    c.drawRightString(W - 40, 22, f"{page:02d} / 04")


