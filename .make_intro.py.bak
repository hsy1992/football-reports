# ================= PAGE 4 验证闭环 =================
header("03", "验证闭环 —— 让数据裁决模型，而不是直觉", "赛果回填 · 每日对账 · 统计门槛保护下的教训回流")

# 左: 循环图
import math as _m
ccx, ccy, R = 218, 280, 128
nodes = [("自动抓取", "30min 节拍"), ("全量存档", "含被动场次"),
         ("赛果回填", "ESPN · 自动"), ("每日对账", "calibrate 09:00"),
         ("校准文件", "calibration.json"), ("模型生效", "analyze 读取")]
pts = []
for i in range(6):
    ang = _m.pi / 2 - i * _m.pi / 3
    pts.append((ccx + R * _m.cos(ang), ccy + R * _m.sin(ang)))
for i in range(6):
    x1, y1 = pts[i]
    x2, y2 = pts[(i + 1) % 6]
    mx, my = (x1 + x2) / 2, (y1 + y2) / 2
    vx, vy = mx - ccx, my - ccy
    n = (vx ** 2 + vy ** 2) ** 0.5
    arrow(x1 + (x2 - x1) * 0.32, y1 + (y2 - y1) * 0.32,
          x1 + (x2 - x1) * 0.68, y1 + (y2 - y1) * 0.68, NAVY)
for i, ((t, s), (px, pyy)) in enumerate(zip(nodes, pts)):
    fill = GREEN if i in (3, 4) else NAVY
    nbox(px - 56, pyy - 21, 112, 42, [t, s], fill=fill, fs=10.5)
c.setFillColor(GRAY)
c.setFont("HeiB", 11)
c.drawCentredString(ccx, ccy + 6, "全自动闭环")
c.setFont("Hei", 8.5)
c.drawCentredString(ccx, ccy - 9, "每一环都有日志可追溯")

